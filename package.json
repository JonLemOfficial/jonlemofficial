{
  "name": "jonlemofficial",
  "description": "Personal portfolio website, built in react/nextjs and other great technologies.",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "next:dev": "next dev",
    "next:build": "next build",
    "next:start": "next start",
    "dev": "docker compose -f config/docker/docker-compose.dev.yml up --build",
    "dev:stop": "docker compose -f config/docker/docker-compose.dev.yml down",
    "build": "docker compose -f config/docker/docker-compose.prod.yml build",
    "start": "docker compose -f config/docker/docker-compose.prod.yml up -d",
    "start:stop": "docker compose -f config/docker/docker-compose.prod.yml down",
    "lint": "eslint"
  },
  "keywords": [
    "portfolio",
    "portfolio-website",
    "react-portfolio",
    "next-portfolio",
    "web-development"
  ],
  "author": {
    "name": "Jonathan \"JonLem\" Lemos",
    "email": "dev@jonlem.com",
    "url": "https://jonlem.com"
  },
  "engines": {
    "node": ">= 22.21.0",
    "npm": ">= 11.14.1",
    "yarn": ">= 1.22.21"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "i18next": "^26.3.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-i18next": "^16.0.7",
    "radix-ui": "^1.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jest": "^30.4.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}